name = "educational-game-leaderboard"
compatibility_date = "2026-07-01"
pages_build_output_dir = "./public"

# This example is for local Wrangler workflows or direct CLI deploys.
# For GitHub-connected Cloudflare Pages, you can also configure the D1
# binding in the Cloudflare Dashboard instead of committing wrangler.toml.
[[d1_databases]]
binding = "DB"
database_name = "educational-game-leaderboard"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

# Set API_SECRET as a Pages/Workers secret, never in this file:
# wrangler pages secret put API_SECRET
